# ============================================
# APPLICATION CONFIGURATION
# ============================================

# Environment (development, staging, production)
NODE_ENV=development

# Server Port
BACKEND_PORT=5000
FRONTEND_HTTP_PORT=3000
FRONTEND_HTTPS_PORT=443

# ============================================
# DATABASE CONFIGURATION
# ============================================

# MongoDB Configuration
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=your_secure_password_here
MONGO_DATABASE=taskmanager
MONGO_PORT=27017

# MongoDB Connection URI (choose one)
# Local MongoDB
MONGODB_URI=mongodb://localhost:27017/taskmanager

# MongoDB Atlas (Cloud)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/taskmanager?retryWrites=true&w=majority

# ============================================
# REDIS CONFIGURATION
# ============================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# ============================================
# JWT AUTHENTICATION
# ============================================

# Generate secure random strings:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

JWT_SECRET=your_very_long_secret_key_for_jwt_tokens_change_this_in_production
JWT_EXPIRE=15m

JWT_REFRESH_SECRET=your_very_long_secret_key_for_refresh_tokens_change_this_too
JWT_REFRESH_EXPIRE=7d

# ============================================
# CORS & CLIENT URL
# ============================================

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000

# Allowed origins (comma-separated for multiple)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80

# ============================================
# EMAIL CONFIGURATION
# ============================================

# SMTP Settings (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_specific_password

# Email From Address
EMAIL_FROM=TaskManager <noreply@taskmanager.com>
EMAIL_FROM_NAME=TaskManager

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================

# Max file size in bytes (5MB = 5242880)
MAX_FILE_SIZE=5242880

# Upload directory
UPLOAD_PATH=./uploads

# Allowed file types (comma-separated)
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# ============================================
# SECURITY CONFIGURATION
# ============================================

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Password Requirements
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=true

# Session
SESSION_SECRET=your_session_secret_change_in_production
SESSION_EXPIRE=86400

# ============================================
# FRONTEND CONFIGURATION
# ============================================

# API URL
REACT_APP_API_URL=http://localhost:5000/api

# Socket URL
REACT_APP_SOCKET_URL=http://localhost:5000

# App Name
REACT_APP_NAME=TaskManager

# Environment
REACT_APP_ENV=development

# ============================================
# ADMIN UI TOOLS
# ============================================

# Mongo Express
MONGO_EXPRESS_PORT=8081
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASS=pass

# Redis Commander
REDIS_COMMANDER_PORT=8082

# ============================================
# LOGGING CONFIGURATION
# ============================================

# Log Level (error, warn, info, debug)
LOG_LEVEL=info

# Log File Path
LOG_FILE_PATH=./logs

# Maximum log file size
LOG_MAX_SIZE=10m

# Maximum number of log files
LOG_MAX_FILES=7

# ============================================
# MONITORING & ANALYTICS
# ============================================

# Sentry DSN (Error Tracking)
SENTRY_DSN=

# Google Analytics ID
GA_TRACKING_ID=

# New Relic License Key
NEW_RELIC_LICENSE_KEY=

# Application Name (for monitoring)
APP_NAME=TaskManager

# ============================================
# CLOUD STORAGE (Optional)
# ============================================

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Google Cloud Storage
GCS_PROJECT_ID=
GCS_BUCKET=
GCS_KEY_FILE=

# ============================================
# NOTIFICATION SERVICES (Optional)
# ============================================

# Firebase Cloud Messaging
FCM_SERVER_KEY=

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ============================================
# CRON JOBS CONFIGURATION
# ============================================

# Enable/Disable scheduled jobs
ENABLE_CRON_JOBS=true

# Daily report time (24-hour format)
DAILY_REPORT_TIME=08:00

# Reminder check interval (minutes)
REMINDER_CHECK_INTERVAL=5

# Auto-archive completed tasks after (days)
AUTO_ARCHIVE_DAYS=30

# ============================================
# DEVELOPMENT TOOLS
# ============================================

# Enable debug mode
DEBUG=false

# Enable API documentation (Swagger)
ENABLE_SWAGGER=true

# Enable request logging
ENABLE_REQUEST_LOGGING=true

# Seed database with sample data
SEED_DATABASE=false

# ============================================
# BACKUP CONFIGURATION
# ============================================

# Backup directory
BACKUP_PATH=./backups

# Backup retention (days)
BACKUP_RETENTION_DAYS=30

# Auto backup schedule (cron format)
BACKUP_SCHEDULE=0 2 * * *

# ============================================
# TESTING CONFIGURATION
# ============================================

# Test database
TEST_MONGODB_URI=mongodb://localhost:27017/taskmanager_test

# Test environment
NODE_ENV_TEST=test

# ============================================
# NOTES
# ============================================

# 1. Copy this file to .env and fill in your values
# 2. NEVER commit .env file to version control
# 3. Use strong, random passwords for production
# 4. Keep secrets secure and rotate them regularly
# 5. Use environment-specific .env files:
#    - .env.development
#    - .env.staging
#    - .env.production
