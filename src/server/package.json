{
  "name": "task-manager-fullstack",
  "version": "1.0.0",
  "description": "Đồ án cuối kì - Lập trình Web Nâng cao (MERN Stack)",
  "scripts": {
    "install-all": "npm install --prefix ../backend && npm install --prefix ../frontend",
    "dev": "concurrently --kill-others-on-fail --names \"BACKEND,FRONTEND\" --prefix-colors \"cyan,magenta\" \"npm run dev --prefix ../backend\" \"npm start --prefix ../frontend\"",
    "backend": "npm run dev --prefix ../backend",
    "frontend": "npm start --prefix ../frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
