# ============================================
# Cấu hình biến môi trường cho Docker
# Sao chép file này: cp .env.example .env
# Sau đó chỉnh sửa giá trị trước khi chạy
# ============================================

# --- MongoDB ---
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=adminpassword
MONGO_DATABASE=taskmanager
MONGO_PORT=27017

# --- JWT (BẮT BUỘC đổi trong production) ---
JWT_SECRET=do_an_cuoi_ki_web_nang_cao_secret_key_2026
JWT_EXPIRE=7d

# --- Ports ---
BACKEND_PORT=5000
FRONTEND_PORT=3000
MONGO_EXPRESS_PORT=8081

# --- Frontend API URL (trỏ đến backend) ---
REACT_APP_API_URL=http://localhost:5000/api
